# MoveCar SaaS - 本地开发环境变量模板
# 复制为 .env.local 后填入真实值
# 完整变量列表见 .env.example

# ------------------------------------------------------------------------------
# 站点基础
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PRICING_PATH="/#pricing"
NEXT_PUBLIC_COOKIE_CONSENT_ENABLED="true"
NEXT_PUBLIC_USER_SOURCE_TRACKING_ENABLED="true"
NEXT_PUBLIC_RATE_LIMIT_ENABLED="false"
NEXT_PUBLIC_EMAIL_NORMALIZATION_ENABLED="false"

# ------------------------------------------------------------------------------
# 数据库（本地或远程 Postgres）
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/movecar"

# ------------------------------------------------------------------------------
# 认证（Better Auth）
# 生成：openssl rand -base64 32
# ------------------------------------------------------------------------------
BETTER_AUTH_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ------------------------------------------------------------------------------
# 安全（可选，本地可留空）
# ------------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ------------------------------------------------------------------------------
# 邮件（Resend）
# ------------------------------------------------------------------------------
RESEND_API_KEY=""
ADMIN_EMAIL=""
ADMIN_NAME=""

# ------------------------------------------------------------------------------
# Redis（Upstash）用于限流与缓存
# ------------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ------------------------------------------------------------------------------
# Stripe 支付（测试模式）
# ------------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_CURRENCY=usd
STRIPE_SECRET_KEY="sk_test_"
STRIPE_PUBLISHABLE_KEY="pk_test_"
STRIPE_WEBHOOK_SECRET="whsec_"
STRIPE_CUSTOMER_PORTAL_URL=/dashboard/subscription
STRIPE_RADAR_EARLY_FRAUD_WARNING_TYPE=refund,email

# MoveCar 定价 Price/Product ID（已创建，可直接使用）
STRIPE_PRICE_ID_PRO_MONTHLY=price_1TuCdvJ0sxpFhqdN8qkm5hJV
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_LIFETIME=price_1TuCdwJ0sxpFhqdNf2s2HLvM
STRIPE_PRODUCT_ID_PRO_MONTHLY=prod_Uu0e7cvIjSjql8
STRIPE_PRODUCT_ID_PRO_YEARLY=
STRIPE_PRODUCT_ID_LIFETIME=prod_Uu0eIb3H86AC1f

# ------------------------------------------------------------------------------
# Creem 支付（中国用户，可选）
# ------------------------------------------------------------------------------
CREEM_API_BASE_URL=https://api.creem.io/v1
CREEM_API_KEY=""
CREEM_WEBHOOK_SECRET=""
CREEM_PRODUCT_ID_PRO_MONTHLY=""
CREEM_PRODUCT_ID_PRO_YEARLY=""
CREEM_PRODUCT_ID_LIFETIME=""

# ------------------------------------------------------------------------------
# R2 对象存储（头像/PDF，可选）
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ------------------------------------------------------------------------------
# MoveCar Worker 与内部 API
# ------------------------------------------------------------------------------
NEXT_PUBLIC_WORKER_URL=http://localhost:8787
WORKER_SECRET=""
CRON_SECRET=""

# ------------------------------------------------------------------------------
# 推送渠道（可选，本地可留空）
# ------------------------------------------------------------------------------
TELEGRAM_MOVECAR_BOT_TOKEN=""
NEXT_PUBLIC_TELEGRAM_MOVECAR_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""

# Firebase Web Push public client configuration
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# ------------------------------------------------------------------------------
# 监控（可选）
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
